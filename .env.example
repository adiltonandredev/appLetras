# ─── Supabase ────────────────────────────────────────────────────────────────
# Crie seu projeto em https://supabase.com e copie as chaves abaixo
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ─── Auth — OAuth ─────────────────────────────────────────────────────────────
# Configure em https://supabase.com/dashboard/project/_/auth/providers
# Google: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# Facebook: https://developers.facebook.com/
FACEBOOK_APP_ID=seu_facebook_app_id
FACEBOOK_APP_SECRET=seu_facebook_app_secret

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Repertório Litúrgico"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Gerado automaticamente pelo Supabase — não alterar em produção
JWT_SECRET=seu_jwt_secret_aqui
