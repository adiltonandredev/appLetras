{
  "name": "repertorio-liturgico",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma de Gestão de Repertório Litúrgico — Monorepo",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:mobile": "turbo run dev --filter=mobile",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "supabase:setup": "bash scripts/setup-supabase.sh",
    "supabase:reset": "bash scripts/reset-db.sh",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:studio": "supabase studio",
    "supabase:push": "supabase db push",
    "supabase:pull": "supabase db pull",
    "supabase:diff": "supabase db diff --use-migra"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "prettier": "^3.2.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
