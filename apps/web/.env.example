# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role — NUNCA exponha no client. Usar apenas no servidor.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Repertório Litúrgico"

# ─── OAuth (configurado no painel Supabase → Auth → Providers) ───────────────
# Google: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook: https://developers.facebook.com/ → My Apps
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
